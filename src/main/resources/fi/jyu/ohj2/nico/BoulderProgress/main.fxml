<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="10.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <children>
        <VBox prefHeight="380.0" prefWidth="440.0" spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
                <TableView fx:id="MonthlyTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="40.0" text="Nro." />
                        <TableColumn prefWidth="110.0" text="Date" />
                        <TableColumn prefWidth="111.0" text="Hardest Grade" />
                        <TableColumn prefWidth="90.0" text="Mode Grade" />
                        <TableColumn prefWidth="88.0" text="Total Climbs" />
                    </columns>
                </TableView>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Button fx:id="ExitButton" mnemonicParsing="false" text="Exit" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="AddButton" mnemonicParsing="false" text="Add" />
                        <Button fx:id="ModifyButton" mnemonicParsing="false" text="Modify" />
                        <Button fx:id="RemoveButton" mnemonicParsing="false" text="Remove" />
                    </children>
                </HBox>
            </children>
        </VBox>
        <VBox prefHeight="380.0" prefWidth="120.0">
            <children>
                <TableView fx:id="Archive" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="118.0" text="Date" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</HBox>