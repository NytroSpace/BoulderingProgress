<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox prefHeight="340.0" prefWidth="600.0">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
            <children>
                <TableView fx:id="SessionTable" pickOnBounds="false" prefHeight="200.0" prefWidth="600.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="GradeColumn" prefWidth="75.0" text="Grade" />
                        <TableColumn fx:id="WallTypeColumn" prefWidth="75.0" text="Wall Type" />
                        <TableColumn fx:id="AttemptsColumn" prefWidth="75.0" text="Attempts" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                <HBox prefHeight="34.0" prefWidth="600.0">
                    <children>
                        <Label fx:id="ModeGrade" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Mode Grade" textAlignment="CENTER" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font></Label>

                        <Label fx:id="ModeWallType" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Mode Wall Type" textAlignment="CENTER" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font></Label>

                        <Label fx:id="TotalAttempts" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Total Attempts" textAlignment="CENTER" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font></Label>
                    </children>
                </HBox>
            </children>
        </VBox>
        <HBox prefHeight="30.0" prefWidth="600.0">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
            <children>
                <Button fx:id="CancelButton" mnemonicParsing="false" prefWidth="80.0" text="Cancel">
                    <HBox.margin>
                        <Insets left="10.0" />
                    </HBox.margin></Button>

                <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />

                <HBox minWidth="200.0" prefWidth="200.0" spacing="10.0">
                    <children>
                        <Button fx:id="RemoveButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Remove" HBox.hgrow="ALWAYS" />
                        <Button fx:id="AddButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Add" HBox.hgrow="ALWAYS" />
                        <Button fx:id="SaveButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Save" HBox.hgrow="ALWAYS" />
                    </children>
                    <HBox.margin>
                        <Insets right="10.0" />
                    </HBox.margin>
                </HBox>
            </children>
        </HBox>
    </children>
</VBox>
